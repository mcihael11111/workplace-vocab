# Root-level environment variable reference
# Each package has its own .env.example with full details.
# This file documents shared context.

# ── Frontend (packages/frontend/.env) ────────────────────────────────────────
VITE_API_URL=http://localhost:3001

# ── Backend (packages/backend/.env) ──────────────────────────────────────────
